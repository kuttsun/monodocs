# syntax=docker/dockerfile:1
#
# monodocs 開発・ビルド・テスト用イメージ。
# Node 22 に pnpm（app/package.json の "packageManager" と同一バージョン）を
# 焼き込み、corepack が実行のたびに pnpm を取得するのを不要にする。
#
# build: docker build -f Dockerfile.dev -t monodocs-dev .
# usage: docker run --rm -it -v "$PWD":/work -w /work/app monodocs-dev pnpm test
#
# ソースコードはイメージに含めず、実行時に作業ツリーをマウントして使う
# （ホスト環境を汚さず、リビルド不要で最新コードを扱える）。
FROM node:22-bookworm-slim

# Mermaid の pre-render（mermaid.mode: pre-render）と PDF 出力（--format pdf/both）は
# puppeteer-core 経由でヘッドレス Chromium を起動する。巨大な puppeteer 同梱 Chromium を
# 落とさず distro の chromium を使い、実行パスを固定する（puppeteer-core は Chromium を同梱しない）。
# フォントは Chromium がシステムフォントを使うため、PDF に出したい文字種の分だけ必要:
# - fonts-noto-cjk … 日本語（CJK）。図の pre-render や本文が豆腐（□）にならないように。
# - fonts-noto-color-emoji … 絵文字（✅ / ⚠️ など）。無いと PDF で豆腐（☒）になる。
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      chromium fonts-liberation fonts-noto-cjk fonts-noto-color-emoji \
 && rm -rf /var/lib/apt/lists/*
ENV PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium \
    PUPPETEER_SKIP_DOWNLOAD=true

# corepack のキャッシュを共有・全ユーザー可読の場所に置く。これにより
# 任意の UID（呼び出しユーザー）で実行しても焼き込んだ pnpm を再ダウンロードしない。
ENV COREPACK_HOME=/opt/corepack

# app/package.json の "packageManager" と必ず揃えること。
ARG PNPM_VERSION=11.9.0
RUN corepack enable \
 && corepack prepare "pnpm@${PNPM_VERSION}" --activate \
 && chmod -R a+rX "$COREPACK_HOME" \
 && pnpm --version

WORKDIR /work/app
