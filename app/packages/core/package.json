{
  "name": "@monodocs/core",
  "version": "0.0.0",
  "private": true,
  "description": "monodocs の変換処理コア（設定読み込み・走査・レンダリング・出力）",
  "license": "MIT",
  "author": "kuttsun",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-theme.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@asciidoctor/core": "^4.0.0",
    "hast-util-to-text": "^4.0.2",
    "mdast-util-to-string": "^4.0.0",
    "mermaid": "^11.16.0",
    "pdf-lib": "^1.17.1",
    "picomatch": "^4.0.4",
    "rehype-parse": "^9.0.1",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.3.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "puppeteer-core": "^24.0.0"
  },
  "devDependencies": {
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.0.0",
    "@types/picomatch": "^4.0.3",
    "@types/unist": "^3.0.3",
    "happy-dom": "^20.10.6"
  }
}
